<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme — ParkMana (light only, no action bar). -->
    <style name="Theme.ParkMana" parent="Theme.MaterialComponents.Light.NoActionBar">

        <!-- Brand / primary colors -->
        <item name="colorPrimary">@color/park_orange</item>
        <item name="colorPrimaryVariant">@color/park_orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary (we reuse the brand orange) -->
        <item name="colorSecondary">@color/park_orange</item>
        <item name="colorSecondaryVariant">@color/park_orange_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Window / background -->
        <item name="android:windowBackground">@color/park_background</item>

        <!-- Status bar: light background, dark icons -->
        <item name="android:statusBarColor">@color/park_background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar: light background, dark icons (API 27+) -->
        <item name="android:navigationBarColor">@color/park_background</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <!-- Splash screen theme: full orange background, white status-bar icons. -->
    <style name="Theme.ParkMana.Splash" parent="Theme.ParkMana">
        <item name="android:windowBackground">@color/park_orange</item>
        <item name="android:statusBarColor">@color/park_orange</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/park_orange</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>

    <!-- Kept from the template; harmless to leave in. -->
    <style name="Theme.ParkMana.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.ParkMana.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.ParkMana.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>