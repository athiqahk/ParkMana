<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Google Map Background -->
    <fragment
        android:id="@+id/navigationMap"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Blue Direction Card -->
    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="90dp"
        android:layout_marginTop="30dp"
        android:layout_gravity="top|center_horizontal"
        android:background="@drawable/bg_blue_card"
        android:orientation="horizontal"
        android:padding="15dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="➜"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/directionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="350 m"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Turn right onto road"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Grey instruction -->
    <TextView
        android:layout_width="160dp"
        android:layout_height="40dp"
        android:layout_marginTop="130dp"
        android:layout_marginStart="25dp"
        android:background="@drawable/bg_grey_label"
        android:gravity="center"
        android:text="Then continue 600"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>

    <!-- Parking label -->
    <TextView
        android:id="@+id/topParkingName"
        android:layout_width="150dp"
        android:layout_height="35dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="55dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_black_label"
        android:gravity="center"
        android:text="Parking"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"/>

    <!-- Bottom Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_card"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/timeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 min"
                    android:textColor="#57B85A"
                    android:textSize="28sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/parkingNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parking"
                    android:textColor="#111111"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/distanceText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="48 bays free on arrival"
                    android:textColor="#777777"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="15dp"
            android:orientation="horizontal">

            <Button
                android:layout_width="110dp"
                android:layout_height="55dp"
                android:text="Cancel"
                android:textColor="#777777"/>

            <Button
                android:id="@+id/startNavigationButton"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_red_rounded"
                android:text="Start Navigation"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>