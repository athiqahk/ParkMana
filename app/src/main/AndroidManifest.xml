<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ParkMana"
        tools:targetApi="31">
        <!-- Splash is the launcher screen, using the orange splash theme. -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.ParkMana.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MainActivity will host onboarding/login/register (no longer the launcher). -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- TEMPORARY placeholder Home — your teammate replaces this later. -->
        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false" />

        <!-- Onboarding (shown to users who aren't signed in). -->
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false" />

        <!-- Login -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false" />

        <!-- Register -->
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false" />
    </application>

</manifest>